#!/usr/bin/env bash
# gpu-hotswitch-vfio - Hot-switch GPU passthrough for KVM virtual machines
# Usage: gpu-hotswitch-vfio {on|off|status|hugepages-alloc|hugepages-free}
#
# Automatically detects discrete GPU (NVIDIA or AMD) and manages:
# - Driver unbinding/rebinding
# - VFIO-PCI binding
#
# Hugepage management is available as separate subcommands.

set -euo pipefail

# --- Auto-detection functions ---
#
# Detection priority:
#   1. vga_switcheroo / switcherooctl — kernel-level GPU type metadata
#   2. Display connection check — on laptops, dGPU has no connected displays
#   3. boot_vga sysfs attribute — boot VGA device is virtually always the iGPU
#   4. PCI bus heuristic (bus != 00:) — last resort, unreliable on some systems
#
# Safety: before any driver unload, we verify the detected dGPU does NOT
# drive active displays.  This prevents accidental iGPU driver removal
# (= black screen).

# Check if a PCI device drives any connected display.
# Returns 0 if at least one display is connected, 1 otherwise.
_has_connected_displays() {
    local pci_addr="$1"
    local card
    for card in /sys/class/drm/card[0-9]*; do
        local dev_path
        dev_path=$(readlink "$card/device" 2>/dev/null || echo "")
        if [[ "$dev_path" != *"/$pci_addr" ]]; then
            continue
        fi
        local conn
        for conn in "$card"/*/status; do
            [[ -f "$conn" ]] || continue
            local status
            status=$(cat "$conn" 2>/dev/null || echo "")
            if [[ "$status" == "connected" ]]; then
                return 0
            fi
        done
        return 1
    done
    return 1  # not a DRM device, so no connected display
}

# Detect dGPU via vga_switcheroo debugfs.
# Outputs the dGPU VGA PCI address on success; returns 1 on failure.
_detect_dgpu_via_switcheroo() {
    local sw="/sys/kernel/debug/vgaswitcheroo/switch"
    [[ -r "$sw" ]] || return 1

    local line
    while IFS= read -r line; do
        # Format: "INDEX:TYPE:FLAGS:PWR:PCI_ADDR"
        # TYPE = DIS (discrete VGA function).  Ignore DIS-AUX audio/helper
        # functions; the IOMMU-group resolver adds those later.
        if [[ "$line" =~ ^[0-9]+:DIS: ]]; then
            if [[ "$line" =~ ([0-9a-fA-F]{4}:[0-9a-fA-F]{2}:[0-9a-fA-F]{2}\.[0-9a-fA-F]) ]]; then
                echo "${BASH_REMATCH[1]}"
                return 0
            fi
        fi
    done < "$sw"
    return 1
}

# Convert switcherooctl's DRI_PRIME=pci-0000_03_00_0 form to a PCI address.
_switcheroo_env_pci() {
    local env_str="$1"
    if [[ "$env_str" =~ DRI_PRIME=pci-([0-9a-fA-F]{4})_([0-9a-fA-F]{2})_([0-9a-fA-F]{2})_([0-9a-fA-F]) ]]; then
        printf '%s:%s:%s.%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" "${BASH_REMATCH[3]}" "${BASH_REMATCH[4]}"
        return 0
    fi
    return 1
}

# Detect dGPU via switcherooctl (same switcheroo metadata as gpu-select).
# This works best for AMD/Mesa GPUs where Environment contains DRI_PRIME=pci-...
_detect_dgpu_via_switcherooctl() {
    command -v switcherooctl &>/dev/null || return 1

    local output
    output=$(switcherooctl list 2>/dev/null) || return 1

    local line discrete="" default_gpu="" env_str=""
    while IFS= read -r line; do
        if [[ "$line" =~ ^Device: ]]; then
            if [[ "$discrete" == "yes" || ( -z "$discrete" && "$default_gpu" == "no" ) ]]; then
                _switcheroo_env_pci "$env_str" && return 0
            fi
            discrete=""
            default_gpu=""
            env_str=""
            continue
        fi

        if [[ "$line" =~ ^[[:space:]]*Discrete:[[:space:]]*(yes|no) ]]; then
            discrete="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^[[:space:]]*Default:[[:space:]]*(yes|no) ]]; then
            default_gpu="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^[[:space:]]*Environment:[[:space:]]*(.*)$ ]]; then
            env_str="${BASH_REMATCH[1]}"
        fi
    done <<< "$output"

    if [[ "$discrete" == "yes" || ( -z "$discrete" && "$default_gpu" == "no" ) ]]; then
        _switcheroo_env_pci "$env_str" && return 0
    fi
    return 1
}

# Resolve a VGA PCI address → GPU type + same-slot GPU functions.
# Output: first line = GPU type (nvidia/amd), rest = PCI addresses.
#
# Do NOT expand to the full IOMMU group here.  Some AMD laptops place the dGPU
# and iGPU in the same IOMMU group; treating the whole group as "the dGPU" can
# include the display-driving iGPU and lead to a black screen.
_resolve_gpu_functions() {
    local vga_addr="$1"
    local gpu_type=""
    local slot="${vga_addr%.*}"

    local dev
    for dev in /sys/bus/pci/devices/"$slot".*; do
        [[ -e "$dev" ]] || continue
        local vendor
        vendor=$(cat "$dev/vendor" 2>/dev/null || echo "")
        case "$vendor" in
            0x10de) gpu_type="nvidia" ;;
            0x1002) [[ -z "$gpu_type" ]] && gpu_type="amd" ;;
        esac
    done

    [[ -n "$gpu_type" ]] || gpu_type="unknown"

    echo "$gpu_type"
    for dev in /sys/bus/pci/devices/"$slot".*; do
        [[ -e "$dev" ]] || continue
        basename "$dev"
    done
}

_is_display_controller() {
    local pci_addr="$1"
    local class
    class=$(cat "/sys/bus/pci/devices/$pci_addr/class" 2>/dev/null || echo "")
    [[ "$class" == 0x03* ]]
}

_other_amdgpu_display_devices() {
    local -A target_devices=()
    local addr
    for addr in "$@"; do
        target_devices["$addr"]=1
    done

    local card
    for card in /sys/class/drm/card[0-9]*; do
        local dev_path pci_addr vendor driver
        dev_path=$(readlink "$card/device" 2>/dev/null || echo "")
        [[ -n "$dev_path" ]] || continue
        pci_addr=$(basename "$dev_path")
        [[ "$pci_addr" =~ ^[0-9a-fA-F]{4}: ]] || continue
        [[ -z "${target_devices[$pci_addr]:-}" ]] || continue

        vendor=$(cat "/sys/bus/pci/devices/$pci_addr/vendor" 2>/dev/null || echo "")
        [[ "$vendor" == "0x1002" ]] || continue
        driver=$(get_current_driver "$pci_addr")
        [[ "$driver" == "amdgpu" ]] || continue

        if _has_connected_displays "$pci_addr"; then
            echo "$pci_addr"
        fi
    done
}

# Find all VGA/3D/Display PCI addresses for our known GPU vendors.
_find_gpu_vga_devices() {
    lspci -D -nn 2>/dev/null | grep -Ei '10de:|1002:' | grep -Ei 'VGA|3D|Display' | awk '{print $1}' || true
}

detect_dgpu() {
    local gpu_type=""
    local -a pci_addrs=()
    local -a vga_candidates=()
    local resolved dgpu_vga

    # --- Method 1: vga_switcheroo (kernel-level, most reliable) ---
    if dgpu_vga=$(_detect_dgpu_via_switcheroo) && [[ -n "$dgpu_vga" ]]; then
        if resolved=$(_resolve_gpu_functions "$dgpu_vga") && [[ -n "$resolved" ]]; then
            gpu_type=$(echo "$resolved" | head -1)
            mapfile -t pci_addrs < <(echo "$resolved" | tail -n +2)
            if [[ -n "$gpu_type" && "$gpu_type" != "unknown" ]]; then
                echo "$gpu_type"
                printf '%s\n' "${pci_addrs[@]}"
                return 0
            fi
        fi
    fi

    # --- Method 1b: switcherooctl (gpu-select-compatible metadata) ---
    if dgpu_vga=$(_detect_dgpu_via_switcherooctl) && [[ -n "$dgpu_vga" ]]; then
        if resolved=$(_resolve_gpu_functions "$dgpu_vga") && [[ -n "$resolved" ]]; then
            gpu_type=$(echo "$resolved" | head -1)
            mapfile -t pci_addrs < <(echo "$resolved" | tail -n +2)
            if [[ -n "$gpu_type" && "$gpu_type" != "unknown" ]]; then
                echo "$gpu_type"
                printf '%s\n' "${pci_addrs[@]}"
                return 0
            fi
        fi
    fi

    # Gather all GPU VGA candidates
    mapfile -t vga_candidates < <(_find_gpu_vga_devices)

    # --- Method 2: Display connection heuristic ---
    # On laptops, the dGPU typically has NO connected displays.
    if [[ ${#vga_candidates[@]} -ge 2 ]]; then
        local -a non_display=()
        local addr
        for addr in "${vga_candidates[@]}"; do
            if ! _has_connected_displays "$addr"; then
                non_display+=("$addr")
            fi
        done

        if [[ ${#non_display[@]} -eq 1 ]]; then
            # Exactly one GPU without displays → dGPU
            if resolved=$(_resolve_gpu_functions "${non_display[0]}") && [[ -n "$resolved" ]]; then
                gpu_type=$(echo "$resolved" | head -1)
                mapfile -t pci_addrs < <(echo "$resolved" | tail -n +2)
                if [[ -n "$gpu_type" && "$gpu_type" != "unknown" ]]; then
                    echo "$gpu_type"
                    printf '%s\n' "${pci_addrs[@]}"
                    return 0
                fi
            fi
        elif [[ ${#non_display[@]} -eq 0 ]]; then
            echo "NOTE: All GPUs have connected displays (desktop setup?)." >&2
        fi
    elif [[ ${#vga_candidates[@]} -eq 1 ]]; then
        local single="${vga_candidates[0]}"
        if _has_connected_displays "$single"; then
            echo "ERROR: Only one GPU detected and it drives the display." >&2
            echo "  Unbinding it will cause a black screen." >&2
            echo "  This script refuses to use a display-driving GPU for passthrough." >&2
            return 1
        fi
        # Single GPU without displays (headless server, or VM host w/ serial console)
        if resolved=$(_resolve_gpu_functions "$single") && [[ -n "$resolved" ]]; then
            gpu_type=$(echo "$resolved" | head -1)
            mapfile -t pci_addrs < <(echo "$resolved" | tail -n +2)
            if [[ -n "$gpu_type" && "$gpu_type" != "unknown" ]]; then
                echo "WARNING: Only one GPU found (headless). Proceeding." >&2
                echo "$gpu_type"
                printf '%s\n' "${pci_addrs[@]}"
                return 0
            fi
        fi
    fi

    # --- Method 3: boot_vga attribute ---
    # The boot VGA device is virtually always the iGPU.
    if [[ ${#vga_candidates[@]} -ge 2 ]]; then
        local boot_vga=""
        local addr
        for addr in "${vga_candidates[@]}"; do
            if [[ "$(cat "/sys/bus/pci/devices/$addr/boot_vga" 2>/dev/null || echo "0")" == "1" ]]; then
                boot_vga="$addr"
                break
            fi
        done
        if [[ -n "$boot_vga" ]]; then
            for addr in "${vga_candidates[@]}"; do
                if [[ "$addr" != "$boot_vga" ]]; then
                    if resolved=$(_resolve_gpu_functions "$addr") && [[ -n "$resolved" ]]; then
                        gpu_type=$(echo "$resolved" | head -1)
                        mapfile -t pci_addrs < <(echo "$resolved" | tail -n +2)
                        if [[ -n "$gpu_type" && "$gpu_type" != "unknown" ]]; then
                            echo "NOTE: Detected dGPU via boot_vga heuristic." >&2
                            echo "$gpu_type"
                            printf '%s\n' "${pci_addrs[@]}"
                            return 0
                        fi
                    fi
                fi
            done
        fi
    fi

    # --- Method 4: Bus heuristic (last resort) ---
    # dGPUs are almost always on a non-root PCI bus (not 00:).
    local -a bus_nonroot=()
    local addr
    for addr in "${vga_candidates[@]}"; do
        if [[ ! "$addr" =~ ^0000:00: ]]; then
            bus_nonroot+=("$addr")
        fi
    done

    if [[ ${#bus_nonroot[@]} -eq 1 ]]; then
        if resolved=$(_resolve_gpu_functions "${bus_nonroot[0]}") && [[ -n "$resolved" ]]; then
            gpu_type=$(echo "$resolved" | head -1)
            mapfile -t pci_addrs < <(echo "$resolved" | tail -n +2)
            if [[ -n "$gpu_type" && "$gpu_type" != "unknown" ]]; then
                echo "WARNING: dGPU detection fell back to PCI bus heuristic." >&2
                echo "  This is unreliable on some systems." >&2
                echo "  Install switcheroo-control for reliable detection:" >&2
                echo "    sudo pacman -S switcheroo-control" >&2
                echo "    sudo systemctl enable --now switcheroo-control.service" >&2
                echo "$gpu_type"
                printf '%s\n' "${pci_addrs[@]}"
                return 0
            fi
        fi
    elif [[ ${#bus_nonroot[@]} -gt 1 ]]; then
        echo "ERROR: Multiple GPUs on non-root buses (${bus_nonroot[*]})." >&2
        echo "  Cannot determine the discrete GPU." >&2
        echo "  Install switcheroo-control: sudo pacman -S switcheroo-control" >&2
        return 1
    fi

    echo "ERROR: No discrete GPU detected." >&2
    echo "  Tried: vga_switcheroo, switcherooctl, display check, boot_vga, bus heuristic." >&2
    return 1
}

get_iommu_group_devices() {
    # Given a PCI address, find all devices in the same IOMMU group
    local pci_addr="$1"
    local iommu_group
    iommu_group=$(basename "$(readlink /sys/bus/pci/devices/"$pci_addr"/iommu_group)")

    for dev in /sys/kernel/iommu_groups/"$iommu_group"/devices/*; do
        basename "$dev"
    done
}

get_current_driver() {
    local pci_addr="$1"
    local driver_link="/sys/bus/pci/devices/$pci_addr/driver"
    if [[ -L "$driver_link" ]]; then
        basename "$(readlink "$driver_link")"
    else
        echo "none"
    fi
}

set_pci_runtime_pm_on() {
    local dev control
    for dev in "$@"; do
        control="/sys/bus/pci/devices/$dev/power/control"
        [[ -w "$control" ]] || continue
        timeout 5 bash -c "echo 'on' > '$control'" 2>/dev/null || {
            echo "  WARNING: failed to disable runtime PM for $dev"
        }
    done
}

# --- Hugepage management ---

get_total_ram_gb() {
    awk '/MemTotal/ {printf "%d", $2 / 1024 / 1024}' /proc/meminfo
}

allocate_hugepages() {
    # Check if any VM actually uses hugepages before allocating
    local needs_hugepages=false
    for xml in /etc/libvirt/qemu/*.xml; do
        [[ -f "$xml" ]] || continue
        if grep -q '<hugepages' "$xml" 2>/dev/null; then
            needs_hugepages=true
            break
        fi
    done

    if [[ "$needs_hugepages" == "false" ]]; then
        echo "No VMs configured with hugepages — skipping allocation."
        return 0
    fi

    # Read VM memory size from the XML that uses hugepages
    local vm_mem_kib=0
    for xml in /etc/libvirt/qemu/*.xml; do
        [[ -f "$xml" ]] || continue
        if grep -q '<hugepages' "$xml" 2>/dev/null; then
            local mem
            mem=$(grep -oP '<memory unit="KiB">\K[0-9]+' "$xml" 2>/dev/null | head -1)
            if [[ -n "$mem" ]] && (( mem > vm_mem_kib )); then
                vm_mem_kib=$mem
            fi
        fi
    done

    local vm_mem_gb=$(( (vm_mem_kib + 1048575) / 1048576 ))  # round up to GB
    if (( vm_mem_gb == 0 )); then
        # Fallback: use half of total RAM
        local total_ram_gb
        total_ram_gb=$(get_total_ram_gb)
        vm_mem_gb=$(( total_ram_gb / 2 ))
    fi

    # Safety check: ensure enough free memory is available
    local available_gb
    available_gb=$(awk '/MemAvailable/ {printf "%d", $2 / 1024 / 1024}' /proc/meminfo)
    if (( vm_mem_gb > available_gb - 2 )); then
        # Leave at least 2GB for the host
        vm_mem_gb=$(( available_gb - 2 ))
        if (( vm_mem_gb <= 0 )); then
            echo "WARNING: Not enough free memory to allocate hugepages (available: ${available_gb}GB)."
            echo "  Skipping hugepage allocation."
            return 0
        fi
        echo "WARNING: Reducing hugepage allocation to ${vm_mem_gb}GB (available: ${available_gb}GB)."
    fi

    echo "Allocating hugepages for ${vm_mem_gb}GB VM memory..."

    # Flush caches and compact memory
    sync
    echo 3 > /proc/sys/vm/drop_caches
    echo 1 > /proc/sys/vm/compact_memory

    if (( vm_mem_gb >= 16 )); then
        # Use 1GB hugepages — allocate incrementally to avoid system freeze
        local nr_pages=$vm_mem_gb
        echo "Using 1GB hugepages: target ${nr_pages} pages (allocating incrementally)..."

        local current=0
        local batch=4  # allocate 4GB at a time
        while (( current < nr_pages )); do
            local target=$(( current + batch ))
            if (( target > nr_pages )); then
                target=$nr_pages
            fi
            echo "$target" > /sys/kernel/mm/hugepages/hugepages-1048576kB/nr_hugepages
            current=$(cat /sys/kernel/mm/hugepages/hugepages-1048576kB/nr_hugepages)
            echo "  Allocated: ${current}/${nr_pages} x 1GB hugepages"
            if (( current < target )); then
                echo "  WARNING: Could only allocate ${current} pages (fragmentation?)"
                break
            fi
            # Brief pause to let system breathe
            sleep 0.2
        done

        echo "Allocated: ${current} x 1GB hugepages"
    else
        # Use 2MB hugepages
        local nr_pages=$(( vm_mem_gb * 1024 / 2 ))
        echo "Using 2MB hugepages: ${nr_pages} pages"
        sysctl -w vm.nr_hugepages="$nr_pages" > /dev/null
        local actual
        actual=$(cat /proc/sys/vm/nr_hugepages)
        echo "Allocated: ${actual} x 2MB hugepages"
    fi
}

release_hugepages() {
    echo "Releasing hugepages..."

    # Release 1GB hugepages if supported
    if [[ -f /sys/kernel/mm/hugepages/hugepages-1048576kB/nr_hugepages ]]; then
        echo 0 > /sys/kernel/mm/hugepages/hugepages-1048576kB/nr_hugepages
    fi
    # Release 2MB hugepages
    sysctl -w vm.nr_hugepages=0 > /dev/null

    echo "Hugepages released"
}

_check_hugepages_advice() {
    # Check if any VM is configured with hugepages
    local has_hugepages=false
    for xml in /etc/libvirt/qemu/*.xml; do
        [[ -f "$xml" ]] || continue
        if grep -q '<hugepages' "$xml" 2>/dev/null; then
            has_hugepages=true
            break
        fi
    done

    if [[ "$has_hugepages" == "true" ]]; then
        echo ""
        echo "TIP: Your VM is configured with hugepages."
        echo "  Run 'gpu-hotswitch-vfio hugepages-alloc' before starting the VM for best performance."
    else
        echo ""
        echo "NOTE: No VMs configured with hugepages. Skipping hugepage allocation."
        echo "  To enable hugepages, add <hugepages/> to <memoryBacking> in your VM XML."
    fi
}

# --- GPU passthrough control ---

# Ensure running compositor ignores dGPU DRM devices and renders on iGPU.
# Currently only niri is handled because it uniquely enumerates and opens ALL
# DRM devices on startup.  Most other compositors (Hyprland, Sway, KDE, GNOME)
# only open the primary GPU by default, so they are unaffected by GPU passthrough.
#
# To add support for another compositor:
#   1. Add a detection block (pgrep -x <compositor>) below the niri section.
#   2. Apply the compositor-specific config to restrict it to the iGPU, e.g.:
#      - wlroots-based (Hyprland, Sway): set WLR_DRM_DEVICES env var
#      - KDE/GNOME/X11: typically no action needed
configure_compositor_ignore_dgpu() {
    local -a gpu_pci_slots=("$@")

    # Only handle niri for now
    pgrep -x niri &>/dev/null || return 0

    # Find niri config for the user who owns the niri process
    local niri_pid niri_user niri_config
    niri_pid=$(pgrep -x niri | head -1)
    niri_user=$(stat -c '%U' "/proc/$niri_pid" 2>/dev/null || echo "")
    [[ -n "$niri_user" ]] || return 0

    if [[ "$niri_user" == "root" ]]; then
        niri_config="/root/.config/niri/config.kdl"
    else
        niri_config="/home/$niri_user/.config/niri/config.kdl"
    fi

    [[ -f "$niri_config" ]] || return 0

    local changed=false

    # Build the lines to insert
    local -a new_lines=()

    # --- Set render-drm-device to iGPU (non-dGPU render device) ---
    if ! grep -q 'render-drm-device' "$niri_config" 2>/dev/null; then
        local igpu_render=""
        for rdev in /dev/dri/by-path/*-render; do
            [[ -e "$rdev" ]] || continue
            local is_dgpu=false
            for slot in "${gpu_pci_slots[@]}"; do
                local base_slot="${slot%.*}.0"
                if [[ "$rdev" == *"$base_slot"* ]]; then
                    is_dgpu=true
                    break
                fi
            done
            if [[ "$is_dgpu" == "false" ]]; then
                igpu_render="$rdev"
                break
            fi
        done

        if [[ -n "$igpu_render" ]]; then
            new_lines+=("    render-drm-device \"$igpu_render\"")
            echo "  Set render-drm-device to $igpu_render"
        fi
    fi

    # --- Add ignore-drm-device for each dGPU PCI slot ---
    for slot in "${gpu_pci_slots[@]}"; do
        local base_slot="${slot%.*}.0"
        local card_path="/dev/dri/by-path/pci-${base_slot}-card"
        local render_path="/dev/dri/by-path/pci-${base_slot}-render"

        if ! grep -qF "$card_path" "$niri_config" 2>/dev/null; then
            new_lines+=("    ignore-drm-device \"$card_path\"")
            new_lines+=("    ignore-drm-device \"$render_path\"")
            echo "  Added ignore-drm-device for $base_slot"
        fi
    done

    if [[ ${#new_lines[@]} -eq 0 ]]; then
        echo "  Compositor config already up to date"
        return 0
    fi

    # Insert lines into the debug {} block using a temp file (avoids sed escaping issues)
    local tmpfile
    tmpfile=$(mktemp)
    local inserted=false
    while IFS= read -r line; do
        echo "$line" >> "$tmpfile"
        if [[ "$inserted" == "false" ]] && [[ "$line" =~ ^[[:space:]]*debug[[:space:]]*\{ ]]; then
            for nl in "${new_lines[@]}"; do
                echo "$nl" >> "$tmpfile"
            done
            inserted=true
        fi
    done < "$niri_config"

    if [[ "$inserted" == "false" ]]; then
        # No debug {} block found, append one
        echo "" >> "$tmpfile"
        echo "debug {" >> "$tmpfile"
        for nl in "${new_lines[@]}"; do
            echo "$nl" >> "$tmpfile"
        done
        echo "}" >> "$tmpfile"
    fi

    cp "$tmpfile" "$niri_config"
    rm -f "$tmpfile"
    changed=true

    if [[ "$changed" == "true" ]]; then
        echo "  Reloading niri config..."
        if command -v niri &>/dev/null; then
            runuser -l "$niri_user" -c 'niri msg action do-screen-transition && niri msg reload' 2>/dev/null || true
        fi
    fi
}

# Safely kill processes using /dev/nvidia* without killing compositor/desktop sessions.
# Shows user a list and asks for confirmation. Uses SIGTERM first, then SIGKILL.
# Automatically stops systemd services whose processes use the GPU (restarted on off).

# Global array to track stopped services for restart during passthrough_off
_stopped_gpu_services=()
_STOPPED_SERVICES_FILE="/run/gpu-hotswitch-vfio-stopped-services"

safe_kill_nvidia_users() {
    # Collect unique PIDs using /dev/nvidia* (all devices including nvidiactl).
    # While nvidiactl-only holders may not actively use the GPU for rendering,
    # they can still prevent full driver unload and device unbinding.
    local -A seen_pids=()
    local -a pids=()
    local raw
    raw=$(fuser /dev/nvidia* 2>/dev/null) || true
    for p in $raw; do
        p="${p%%[a-zA-Z]*}"
        if [[ -n "$p" && -z "${seen_pids[$p]:-}" ]]; then
            pids+=("$p")
            seen_pids[$p]=1
        fi
    done

    if [[ ${#pids[@]} -eq 0 ]]; then
        return 0
    fi

    # Compositors / desktop sessions we must never kill
    local -a protected_re=(
        'niri' 'hyprland' 'sway' 'kwin' 'gnome-shell' 'mutter'
        'weston' 'labwc' 'wayfire' 'Xorg' 'Xwayland'
        'xwayland-satellite' 'quickshell' 'dms-shell'
        'gdm' 'sddm' 'greetd' 'tuigreet' 'login'
    )
    local re
    re=$(IFS='|'; echo "${protected_re[*]}")

    # Categorize processes: service-managed vs user processes
    # For user processes, find the top-level application process to kill the whole app.
    # Electron/Chromium spawn GPU subprocesses; killing only the subprocess causes respawn.
    local -a service_pids=()
    local -a service_units=()
    local -a killable_pids=()
    local -a killable_names=()
    local -A seen_units=()
    local -A seen_app_pids=()

    for pid in "${pids[@]}"; do
        local comm
        comm=$(cat "/proc/$pid/comm" 2>/dev/null || echo "")
        if [[ -z "$comm" ]]; then
            continue
        fi
        # Skip protected processes
        if echo "$comm" | grep -qEi "($re)"; then
            echo "  Protected (will not kill): $comm (PID $pid)"
            continue
        fi

        # Check if this process belongs to a systemd service
        local unit=""
        if [[ -f "/proc/$pid/cgroup" ]]; then
            unit=$(grep -oE '[^/]+\.service$' "/proc/$pid/cgroup" 2>/dev/null | head -1 || true)
        fi

        if [[ -n "$unit" && -z "${seen_units[$unit]:-}" ]]; then
            seen_units[$unit]=1
            service_pids+=("$pid")
            service_units+=("$unit")
        elif [[ -z "$unit" ]]; then
            # Trace parent chain to find the top-level application process.
            # Walk up as long as parent has the same comm name (e.g. msedge → msedge).
            # This finds the main process of multi-process apps (electron, chromium).
            local app_pid="$pid"
            local app_comm="$comm"
            while true; do
                local ppid
                ppid=$(awk '/PPid/ {print $2}' "/proc/$app_pid/status" 2>/dev/null || echo "1")
                [[ "$ppid" != "1" && "$ppid" != "0" && -d "/proc/$ppid" ]] || break
                local parent_comm
                parent_comm=$(cat "/proc/$ppid/comm" 2>/dev/null || echo "")
                [[ -n "$parent_comm" ]] || break
                # Only follow parents with the same comm name
                if [[ "$parent_comm" == "$app_comm" ]]; then
                    app_pid="$ppid"
                else
                    break
                fi
            done

            if [[ -z "${seen_app_pids[$app_pid]:-}" ]]; then
                seen_app_pids[$app_pid]=1
                # Final check: don't add if the app itself is protected
                if echo "$app_comm" | grep -qEi "($re)"; then
                    echo "  Protected (will not kill): $app_comm (PID $app_pid)"
                    continue
                fi
                killable_pids+=("$app_pid")
                killable_names+=("$app_comm")
            fi
        fi
    done

    # Auto-stop systemd services (no user prompt needed)
    if [[ ${#service_units[@]} -gt 0 ]]; then
        echo ""
        echo "  Stopping systemd services using the GPU:"
        for unit in "${service_units[@]}"; do
            echo "    • $unit"
            systemctl stop "$unit" 2>/dev/null || true
            _stopped_gpu_services+=("$unit")
        done
        # Persist stopped services list for passthrough_off
        printf '%s\n' "${_stopped_gpu_services[@]}" > "$_STOPPED_SERVICES_FILE"
    fi

    # Re-check remaining PIDs after stopping services
    local -a remaining_pids=()
    local -a remaining_names=()
    for i in "${!killable_pids[@]}"; do
        if [[ -d "/proc/${killable_pids[$i]}" ]]; then
            remaining_pids+=("${killable_pids[$i]}")
            remaining_names+=("${killable_names[$i]}")
        fi
    done

    if [[ ${#remaining_pids[@]} -eq 0 ]]; then
        return 0
    fi

    # Display applications and ask for confirmation
    echo ""
    echo "  The following applications are using the NVIDIA GPU:"
    echo "  ────────────────────────────────────────────────────"
    for i in "${!remaining_pids[@]}"; do
        local pid="${remaining_pids[$i]}"
        local comm="${remaining_names[$i]}"
        local cmdline
        cmdline=$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null | head -c 80 || echo "")
        printf "    [%d] %s (PID %s)\n" "$((i+1))" "$comm" "$pid"
        if [[ -n "$cmdline" && "$cmdline" != "$comm "* ]]; then
            printf "        %s\n" "$cmdline"
        fi
    done
    echo ""

    # If running non-interactively (no tty), kill without asking
    if [[ ! -t 0 ]]; then
        echo "  Non-interactive mode: terminating all GPU users..."
    else
        echo -n "  Terminate these processes to proceed? [Y/n] "
        local answer
        read -r answer < /dev/tty
        if [[ "$answer" =~ ^[Nn] ]]; then
            echo "  Aborted by user."
            return 1
        fi
    fi

    # SIGTERM first (graceful shutdown) — kill app and its children
    echo "  Sending SIGTERM..."
    for pid in "${remaining_pids[@]}"; do
        # Kill all descendants first, then the app itself
        pkill -TERM -P "$pid" 2>/dev/null || true
        kill -TERM "$pid" 2>/dev/null || true
    done

    # Wait up to 15 seconds for graceful exit
    local timeout=15
    local waited=0
    while (( waited < timeout )); do
        local still_running=false
        for pid in "${remaining_pids[@]}"; do
            if [[ -d "/proc/$pid" ]]; then
                still_running=true
                break
            fi
        done
        if [[ "$still_running" == "false" ]]; then
            echo "  All processes exited gracefully."
            return 0
        fi
        local remaining=$(( timeout - waited ))
        printf "\r  Waiting for processes to exit... %ds remaining" "$remaining"
        sleep 1
        waited=$(( waited + 1 ))
    done
    echo ""

    # SIGKILL remaining process trees
    echo "  Some processes didn't exit, sending SIGKILL..."
    for pid in "${remaining_pids[@]}"; do
        if [[ -d "/proc/$pid" ]]; then
            local comm
            comm=$(cat "/proc/$pid/comm" 2>/dev/null || echo "PID $pid")
            echo "    Force killing: $comm (PID $pid) and children"
            pkill -9 -P "$pid" 2>/dev/null || true
            kill -9 "$pid" 2>/dev/null || true
        fi
    done
    sleep 0.5
}

# Restart services that were stopped for GPU passthrough.
# Attempts to start each; logs success/failure. Retries once on failure.
# Does NOT remove the tracking file (caller decides when to clean up).
_restart_stopped_services() {
    if [[ ! -f "$_STOPPED_SERVICES_FILE" ]]; then
        return 0
    fi
    echo "Restarting GPU-related services..."

    # Start all services
    local -a started_svcs=()
    while IFS= read -r svc; do
        [[ -n "$svc" ]] || continue
        # Reset failed state to avoid start-limit-hit from prior failures
        systemctl reset-failed "$svc" 2>/dev/null || true
        if systemctl start "$svc" 2>/dev/null; then
            started_svcs+=("$svc")
        else
            echo "  ✗ $svc failed to start"
        fi
    done < "$_STOPPED_SERVICES_FILE"

    if [[ ${#started_svcs[@]} -eq 0 ]]; then
        return 0
    fi

    # Wait once, then check all
    sleep 2
    for svc in "${started_svcs[@]}"; do
        if systemctl is-active "$svc" &>/dev/null; then
            echo "  ✓ $svc running"
        else
            echo "  ✗ $svc exited shortly after start (GPU may be unavailable)"
        fi
    done
}

# Stop services listed in the stopped-services file (for passthrough_off).
_stop_tracked_services() {
    if [[ ! -f "$_STOPPED_SERVICES_FILE" ]]; then
        return 0
    fi
    echo "Stopping GPU-related services before driver switch..."
    while IFS= read -r svc; do
        [[ -n "$svc" ]] || continue
        if systemctl is-active "$svc" &>/dev/null; then
            if systemctl stop "$svc" 2>/dev/null; then
                echo "  ✓ $svc stopped"
            else
                echo "  ✗ $svc failed to stop"
            fi
        fi
    done < "$_STOPPED_SERVICES_FILE"
}

passthrough_on() {
    echo "=== Enabling GPU VFIO passthrough ==="

    # Detect GPU
    local detection
    detection=$(detect_dgpu)
    local gpu_type
    gpu_type=$(echo "$detection" | head -1)
    local -a gpu_addrs
    mapfile -t gpu_addrs < <(echo "$detection" | tail -n +2)

    # --- Safety: verify dGPU does NOT drive active displays ---
    # If the detected dGPU has connected displays, we may have misidentified
    # it (it's actually the iGPU).  Unbinding it would black-screen the host.
    local _safety_fail=false
    local addr
    for addr in "${gpu_addrs[@]}"; do
        if _has_connected_displays "$addr"; then
            echo "SAFETY ERROR: GPU device $addr has connected displays!" >&2
            echo "  This GPU may be your iGPU.  Refusing to unbind it." >&2
            echo "  If you are certain this is the dGPU and want to proceed," >&2
            echo "  physically disconnect the display from this GPU first." >&2
            _safety_fail=true
        fi
    done
    if [[ "$_safety_fail" == "true" ]]; then
        return 1
    fi
    echo "Detected ${gpu_type} GPU functions at: ${gpu_addrs[*]}"

    # Collect all IOMMU group devices for the selected dGPU functions.
    # VFIO isolation is at IOMMU-group granularity, but the detected GPU
    # identity remains limited to same-slot dGPU functions above.
    local -a all_devices=()
    local -A seen_devices=()
    for addr in "${gpu_addrs[@]}"; do
        while IFS= read -r dev; do
            if [[ -z "${seen_devices[$dev]:-}" ]]; then
                all_devices+=("$dev")
                seen_devices[$dev]=1
            fi
        done < <(get_iommu_group_devices "$addr")
    done

    if [[ ${#all_devices[@]} -eq 0 ]]; then
        echo "ERROR: No IOMMU group devices found. Cannot proceed." >&2
        return 1
    fi

    echo "IOMMU group devices: ${all_devices[*]}"

    # Abort before touching drivers if this IOMMU group also contains another
    # display controller.  Binding the whole group would take the host GPU down;
    # binding only part of the group would not be VFIO-isolated.
    local -A target_devices=()
    for addr in "${gpu_addrs[@]}"; do
        target_devices["$addr"]=1
    done

    local -a unsafe_group_devices=()
    for dev in "${all_devices[@]}"; do
        [[ -z "${target_devices[$dev]:-}" ]] || continue
        if _has_connected_displays "$dev" || _is_display_controller "$dev"; then
            unsafe_group_devices+=("$dev")
        fi
    done

    if [[ ${#unsafe_group_devices[@]} -gt 0 ]]; then
        echo "ERROR: dGPU IOMMU group contains non-target display/GPU devices:" >&2
        local dev
        for dev in "${unsafe_group_devices[@]}"; do
            local class driver
            class=$(cat "/sys/bus/pci/devices/$dev/class" 2>/dev/null || echo "unknown")
            driver=$(get_current_driver "$dev")
            echo "  $dev (class: $class, driver: $driver)" >&2
        done
        echo "Refusing to switch drivers because this would risk the host display." >&2
        echo "Use an IOMMU/ACS layout where the dGPU functions are isolated first." >&2
        return 1
    fi

    # Keep target devices fully powered during detach/bind.  Runtime PM after
    # vfio-pci bind has triggered kernel hangs on this platform.
    echo "Disabling runtime PM for passthrough devices..."
    set_pci_runtime_pm_on "${all_devices[@]}"

    # AMD iGPU+dGPU systems share one amdgpu kernel module.  If another AMD
    # GPU is driving the host display through amdgpu, we must not unload the
    # module; instead, detach only the selected dGPU functions from amdgpu.
    local amd_per_device_unbind=false
    if [[ "$gpu_type" == "amd" ]]; then
        local -a other_amd_displays=()
        mapfile -t other_amd_displays < <(_other_amdgpu_display_devices "${gpu_addrs[@]}")
        if [[ ${#other_amd_displays[@]} -gt 0 ]]; then
            echo "AMD host display GPU remains on amdgpu:"
            local dev
            for dev in "${other_amd_displays[@]}"; do
                echo "  $dev"
            done
            echo "Using per-device amdgpu unbind for the dGPU; the iGPU module stays loaded."
            amd_per_device_unbind=true
        fi
    fi

    # Configure compositor to ignore dGPU DRM devices BEFORE killing anything
    echo "Ensuring compositor ignores dGPU..."
    configure_compositor_ignore_dgpu "${gpu_addrs[@]}"

    case "$gpu_type" in
        nvidia)
            # Retry loop: kill GPU users, then try to unload modules.
            # Some processes respawn or take time to release the device.
            local max_attempts=5
            local attempt=0
            while (( attempt < max_attempts )); do
                attempt=$(( attempt + 1 ))
                echo "Attempt $attempt/$max_attempts: stopping NVIDIA GPU users..."
                if ! safe_kill_nvidia_users; then
                    echo "Aborted."
                    return 1
                fi

                echo "Unloading NVIDIA modules..."
                for mod in nvidia_drm nvidia_modeset nvidia_uvm nvidia; do
                    rmmod "$mod" 2>/dev/null || true
                done

                if ! lsmod | grep -q '^nvidia'; then
                    echo "NVIDIA modules unloaded successfully."
                    # Verify device is actually unbound
                    local still_bound=false
                    for addr in "${gpu_addrs[@]}"; do
                        local drv
                        drv=$(get_current_driver "$addr")
                        if [[ "$drv" == "nvidia" ]]; then
                            still_bound=true
                            break
                        fi
                    done
                    if [[ "$still_bound" == "true" ]]; then
                        echo "  WARNING: Module removed but device still shows nvidia binding."
                        echo "  Waiting for kernel to release..."
                        sleep 2
                    fi
                    break
                fi

                if (( attempt < max_attempts )); then
                    echo "  Modules still loaded, retrying in 2s..."
                    # Show what's still holding the device
                    fuser -v /dev/nvidia* 2>/dev/null || true
                    sleep 2
                fi
            done

            if lsmod | grep -q '^nvidia'; then
                echo "WARNING: nvidia module still loaded after $max_attempts attempts."
                echo "  Remaining users:"
                fuser -v /dev/nvidia* 2>/dev/null || true
                echo "  Proceeding with forced unbind via sysfs..."
            fi
            ;;
        amd)
            # AMD uses /dev/dri/card*, renderD*, and per-GPU I2C adapters.
            # DMS/monitor tools may hold only /dev/i2c-* for the dGPU; if they
            # touch that adapter while amdgpu is unbinding, amdgpu can oops in
            # amdgpu_dm_i2c_xfer/dm_read_reg_func.  Treat those I2C nodes as
            # dGPU users too, and wait until they are gone before unbind.
            echo "Stopping AMD GPU users..."
            local -A seen_amd_nodes=()
            local -a amd_nodes=()
            for addr in "${gpu_addrs[@]}"; do
                local base="${addr%.*}.0"
                local node
                for node in "/dev/dri/by-path/pci-${base}-card" "/dev/dri/by-path/pci-${base}-render"; do
                    if [[ -e "$node" ]]; then
                        local resolved_node
                        resolved_node=$(readlink -f "$node")
                        if [[ -z "${seen_amd_nodes[$resolved_node]:-}" ]]; then
                            amd_nodes+=("$resolved_node")
                            seen_amd_nodes["$resolved_node"]=1
                        fi
                    fi
                done

                local i2c_dev
                for i2c_dev in /sys/bus/pci/devices/"$base"/i2c-*/i2c-dev/i2c-*; do
                    [[ -e "$i2c_dev" ]] || continue
                    node="/dev/$(basename "$i2c_dev")"
                    if [[ -e "$node" && -z "${seen_amd_nodes[$node]:-}" ]]; then
                        amd_nodes+=("$node")
                        seen_amd_nodes["$node"]=1
                    fi
                done
            done

            if [[ ${#amd_nodes[@]} -gt 0 ]]; then
                local amd_raw
                amd_raw=$(fuser "${amd_nodes[@]}" 2>/dev/null | tr -s ' ') || true
                if [[ -n "$amd_raw" ]]; then
                    echo "  Processes using AMD dGPU nodes:"
                    fuser -v "${amd_nodes[@]}" 2>/dev/null || true

                    local -A seen_amd_pids=()
                    local -a amd_pids=()
                    local p
                    for p in $amd_raw; do
                        p="${p%%[a-zA-Z]*}"
                        if [[ -n "$p" && -z "${seen_amd_pids[$p]:-}" ]]; then
                            amd_pids+=("$p")
                            seen_amd_pids["$p"]=1
                        fi
                    done

                    local -a protected_re=(
                        'niri' 'hyprland' 'sway' 'kwin' 'gnome-shell' 'mutter'
                        'weston' 'labwc' 'wayfire' 'Xorg' 'Xwayland'
                        'xwayland-satellite' 'quickshell' 'dms-shell'
                        'gdm' 'sddm' 'greetd' 'tuigreet' 'login'
                    )
                    local re protected_found=false
                    re=$(IFS='|'; echo "${protected_re[*]}")

                    for p in "${amd_pids[@]}"; do
                        local comm
                        comm=$(cat "/proc/$p/comm" 2>/dev/null || echo "")
                        if [[ -n "$comm" ]] && echo "$comm" | grep -qEi "($re)"; then
                            echo "  Protected process still holds the dGPU: $comm (PID $p)" >&2
                            protected_found=true
                        fi
                    done
                    if [[ "$protected_found" == "true" ]]; then
                        echo "  Reload/stop the compositor or close the session using the dGPU, then retry." >&2
                        return 1
                    fi

                    echo "  Sending SIGTERM..."
                    for p in "${amd_pids[@]}"; do
                        [[ -n "$p" ]] || continue
                        pkill -TERM -P "$p" 2>/dev/null || true
                        kill -TERM "$p" 2>/dev/null || true
                    done

                    local waited=0
                    while (( waited < 10 )); do
                        amd_raw=$(fuser "${amd_nodes[@]}" 2>/dev/null | tr -s ' ') || true
                        [[ -z "$amd_raw" ]] && break
                        sleep 1
                        waited=$(( waited + 1 ))
                    done

                    if [[ -n "$amd_raw" ]]; then
                        echo "  Some AMD dGPU users did not exit, sending SIGKILL..."
                        local -A killed=()
                        for p in $amd_raw; do
                            p="${p%%[a-zA-Z]*}"
                            [[ -n "$p" && -z "${killed[$p]:-}" ]] || continue
                            killed["$p"]=1
                            pkill -KILL -P "$p" 2>/dev/null || true
                            kill -KILL "$p" 2>/dev/null || true
                        done
                        sleep 1
                        amd_raw=$(fuser "${amd_nodes[@]}" 2>/dev/null | tr -s ' ') || true
                        if [[ -n "$amd_raw" ]]; then
                            echo "  ERROR: dGPU nodes are still in use; refusing to unbind amdgpu." >&2
                            fuser -v "${amd_nodes[@]}" 2>/dev/null || true
                            return 1
                        fi
                    fi
                fi
            fi

            if [[ "$amd_per_device_unbind" == "true" ]]; then
                echo "Unbinding AMD dGPU functions from amdgpu (iGPU stays active)..."
                for addr in "${gpu_addrs[@]}"; do
                    local current_driver
                    current_driver=$(get_current_driver "$addr")
                    if [[ "$current_driver" == "amdgpu" ]]; then
                        timeout 5 bash -c "echo '$addr' > /sys/bus/pci/drivers/amdgpu/unbind" 2>/dev/null || {
                            echo "  ERROR: amdgpu unbind of $addr timed out or failed." >&2
                            return 1
                        }
                    fi
                done

                for addr in "${gpu_addrs[@]}"; do
                    if [[ "$(get_current_driver "$addr")" == "amdgpu" ]]; then
                        echo "  ERROR: $addr is still bound to amdgpu after unbind." >&2
                        return 1
                    fi
                done
            else
                echo "Unloading AMD GPU module..."
                rmmod amdgpu 2>/dev/null || true

                if lsmod | grep -q '^amdgpu'; then
                    echo "WARNING: amdgpu module still loaded."
                    echo "  Some processes may still be using the GPU."
                fi
            fi
            ;;
    esac

    # Unbind all remaining non-GPU devices from current drivers.
    # GPU drivers must already be detached by the vendor-specific path above:
    # NVIDIA via rmmod, AMD either via rmmod or selected per-device amdgpu unbind
    # when the host iGPU keeps the shared amdgpu module loaded.
    echo "Unbinding devices from current drivers..."
    for dev in "${all_devices[@]}"; do
        local current_driver
        current_driver=$(get_current_driver "$dev")
        if [[ "$current_driver" == "none" || "$current_driver" == "vfio-pci" ]]; then
            continue
        fi
        # GPU drivers should already be gone; do not try an unplanned fallback here.
        if [[ "$current_driver" == "nvidia" || "$current_driver" == "amdgpu" || "$current_driver" == "nouveau" ]]; then
            echo "  $dev: still bound to $current_driver"
            echo "  ERROR: GPU driver detach did not complete. Aborting." >&2
            return 1
        fi
        # Non-GPU drivers (e.g. snd_hda_intel) are safe to unbind
        if [[ ! -d "/sys/bus/pci/drivers/$current_driver" ]]; then
            echo "  $dev: driver $current_driver already removed, skipping"
            continue
        fi
        echo "  Unbinding $dev from $current_driver"
        timeout 5 bash -c "echo '$dev' > '/sys/bus/pci/drivers/$current_driver/unbind'" 2>/dev/null || {
            echo "  WARNING: unbind of $dev timed out or failed (may already be unbound)"
        }
    done

    # Load vfio-pci and bind devices
    echo "Loading vfio-pci module..."
    if ! modprobe vfio-pci 2>/dev/null; then
        # vfio-pci may be built into the kernel — check if driver is available
        if [[ ! -d /sys/bus/pci/drivers/vfio-pci ]]; then
            echo "  ERROR: vfio-pci module not found and driver not available." >&2
            echo "  Ensure CONFIG_VFIO_PCI is enabled in your kernel." >&2
            return 1
        fi
        echo "  vfio-pci is built-in (not a loadable module)."
    fi

    echo "Binding devices to vfio-pci..."
    for dev in "${all_devices[@]}"; do
        timeout 5 bash -c "echo 'vfio-pci' > '/sys/bus/pci/devices/$dev/driver_override'" || {
            echo "  ERROR: Failed to set driver_override for $dev" >&2
            return 1
        }
        timeout 5 bash -c "echo '$dev' > /sys/bus/pci/drivers_probe" || {
            echo "  ERROR: Failed to probe $dev" >&2
            return 1
        }
        # Prevent vfio-pci runtime-suspend on this hot-detached GPU.  On this
        # platform vfio_pci_core_runtime_suspend has triggered a kernel oops,
        # leaving later lspci/virt-manager probes stuck in pm_runtime_barrier.
        set_pci_runtime_pm_on "$dev"
    done

    # Check if VMs use hugepages and advise user
    _check_hugepages_advice

    # Restart stopped services — they will now bind to iGPU since dGPU is gone
    _restart_stopped_services

    echo "=== GPU VFIO passthrough enabled ==="
    echo "You can now start your VM with GPU passthrough."
}

passthrough_off() {
    echo "=== Disabling GPU VFIO passthrough ==="

    # Check if passthrough is actually active
    if [[ ! -d /sys/bus/pci/drivers/vfio-pci ]] || \
       ! ls /sys/bus/pci/drivers/vfio-pci/*/vendor &>/dev/null; then
        echo "GPU passthrough is not active. Nothing to do."
        return 0
    fi

    # Stop services that were restarted on iGPU, before switching driver back
    _stop_tracked_services

    # Detect GPU type
    local detection
    detection=$(detect_dgpu 2>/dev/null) || true
    local gpu_type

    # If detection fails (GPU bound to vfio), try to determine from loaded modules
    if [[ -z "$detection" ]]; then
        # Check vfio-bound devices to determine GPU type
        for dev in /sys/bus/pci/drivers/vfio-pci/*/; do
            local pci_addr
            pci_addr=$(basename "$dev")
            [[ "$pci_addr" =~ ^[0-9a-fA-F]{4}: ]] || continue
            local vendor
            vendor=$(cat "/sys/bus/pci/devices/$pci_addr/vendor" 2>/dev/null || echo "")
            case "$vendor" in
                0x10de) gpu_type="nvidia"; break ;;
                0x1002) gpu_type="amd"; break ;;
            esac
        done
    else
        gpu_type=$(echo "$detection" | head -1)
    fi

    if [[ -z "${gpu_type:-}" ]]; then
        echo "ERROR: Cannot determine GPU type" >&2
        return 1
    fi

    # Find all vfio-pci bound devices
    local -a vfio_devices=()
    for dev_path in /sys/bus/pci/drivers/vfio-pci/*/; do
        [[ -d "$dev_path" ]] || continue
        local pci_addr
        pci_addr=$(basename "$dev_path")
        # Skip non-PCI entries like "module"
        [[ "$pci_addr" =~ ^[0-9a-fA-F]{4}: ]] || continue
        # Only process GPU-related devices (vendor 10de or 1002)
        local vendor
        vendor=$(cat "/sys/bus/pci/devices/$pci_addr/vendor" 2>/dev/null || echo "")
        if [[ "$vendor" == "0x10de" || "$vendor" == "0x1002" ]]; then
            vfio_devices+=("$pci_addr")
        fi
    done

    echo "Disabling runtime PM for vfio-pci devices..."
    set_pci_runtime_pm_on "${vfio_devices[@]}"

    # Clear driver overrides and unbind from vfio-pci
    echo "Unbinding devices from vfio-pci..."
    for dev in "${vfio_devices[@]}"; do
        timeout 5 bash -c "echo '' > '/sys/bus/pci/devices/$dev/driver_override'" 2>/dev/null || true
        timeout 5 bash -c "echo '$dev' > /sys/bus/pci/drivers/vfio-pci/unbind" 2>/dev/null || true
    done

    # Reload original driver
    case "$gpu_type" in
        nvidia)
            echo "Reloading NVIDIA modules..."
            modprobe nvidia
            modprobe nvidia_drm
            modprobe nvidia_modeset
            modprobe nvidia_uvm
            ;;
        amd)
            echo "Reloading AMD GPU module..."
            modprobe amdgpu
            ;;
    esac

    # Reprobe devices
    echo "Reprobing devices..."
    for dev in "${vfio_devices[@]}"; do
        timeout 5 bash -c "echo '$dev' > /sys/bus/pci/drivers_probe" 2>/dev/null || true
        set_pci_runtime_pm_on "$dev"
    done

    # Release hugepages if any are allocated
    local hp_1g=0 hp_2m=0
    if [[ -f /sys/kernel/mm/hugepages/hugepages-1048576kB/nr_hugepages ]]; then
        hp_1g=$(cat /sys/kernel/mm/hugepages/hugepages-1048576kB/nr_hugepages)
    fi
    hp_2m=$(cat /proc/sys/vm/nr_hugepages)
    if (( hp_1g > 0 || hp_2m > 0 )); then
        echo "Releasing hugepages..."
        release_hugepages
    fi

    # Restart services — dGPU is now available again
    _restart_stopped_services
    rm -f "$_STOPPED_SERVICES_FILE"

    echo "=== GPU VFIO passthrough disabled ==="
}

_pci_device_summary() {
    local pci_addr="$1"
    local class vendor device
    class=$(cat "/sys/bus/pci/devices/$pci_addr/class" 2>/dev/null || echo "unknown")
    vendor=$(cat "/sys/bus/pci/devices/$pci_addr/vendor" 2>/dev/null || echo "unknown")
    device=$(cat "/sys/bus/pci/devices/$pci_addr/device" 2>/dev/null || echo "unknown")
    echo "$pci_addr class=$class vendor=$vendor device=$device"
}

passthrough_status() {
    echo "=== GPU VFIO Hotswitch Status ==="

    # Avoid `lspci -k` here.  On some systems it can hang after runtime
    # GPU detachment; sysfs driver links are enough for status and are safer.
    echo ""
    echo "GPU Devices:"
    local found_gpu=false
    local dev_path pci_addr class driver
    for dev_path in /sys/bus/pci/devices/*; do
        [[ -d "$dev_path" ]] || continue
        pci_addr=$(basename "$dev_path")
        class=$(cat "$dev_path/class" 2>/dev/null || echo "")
        [[ "$class" == 0x03* ]] || continue
        found_gpu=true
        driver=$(get_current_driver "$pci_addr")
        echo "  $(_pci_device_summary "$pci_addr")"
        echo "      Driver: $driver"
        if _has_connected_displays "$pci_addr"; then
            echo "      Displays: connected"
        fi
    done
    if [[ "$found_gpu" == "false" ]]; then
        echo "  (none)"
    fi

    echo ""
    echo "VFIO-PCI bound devices:"
    local found_vfio=false
    if [[ -d /sys/bus/pci/drivers/vfio-pci ]]; then
        for dev_path in /sys/bus/pci/drivers/vfio-pci/*; do
            [[ -e "$dev_path" ]] || continue
            pci_addr=$(basename "$dev_path")
            [[ "$pci_addr" =~ ^[0-9a-fA-F]{4}: ]] || continue
            found_vfio=true
            echo "  $(_pci_device_summary "$pci_addr")"
        done
        if [[ "$found_vfio" == "false" ]]; then
            echo "  (none)"
        fi
    else
        echo "  vfio-pci module not loaded"
    fi

    echo ""
    echo "Hugepages:"
    echo "  2MB: $(cat /proc/sys/vm/nr_hugepages) allocated"
    if [[ -f /sys/kernel/mm/hugepages/hugepages-1048576kB/nr_hugepages ]]; then
        echo "  1GB: $(cat /sys/kernel/mm/hugepages/hugepages-1048576kB/nr_hugepages) allocated"
    fi

    echo ""
    echo "Total RAM: $(get_total_ram_gb) GB"
}

# --- Main ---

if [[ $EUID -ne 0 ]]; then
    echo "ERROR: This script must be run as root (use sudo)" >&2
    exit 1
fi

case "${1:-}" in
    on)  passthrough_on ;;
    off) passthrough_off ;;
    status) passthrough_status ;;
    hugepages-alloc) allocate_hugepages ;;
    hugepages-free)  release_hugepages ;;
    *)
        echo "Usage: gpu-hotswitch-vfio {on|off|status|hugepages-alloc|hugepages-free}" >&2
        exit 1
        ;;
esac
